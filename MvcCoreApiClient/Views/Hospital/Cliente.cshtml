@section Scripts {
    <script>
        $(document).ready(function(){
            $("#btnhospitales").click(function(){
                let url = "https://apicorehospitalmqmp.azurewebsites.net/"
                let request = "api/hospital"
                $.ajax({
                    url: url + request,
                    method: "GET",
                    success: function(data){
                        var html = ""
                        $.each(data, function(index, hospital){
                            html += "<tr>"
                            html += "<td>" + hospital.nombre + "</td>"
                            html += "<td>" + hospital.direccion + "</td>"
                            html += "<td>" + hospital.telefono + "</td>"
                            html += "<td>" + hospital.camas + "</td>"
                            html += "</tr>"
                        })
                        $("#tablahospitales tbody").html(html)
                    }
                })
            })
        })
    </script>
}
<div class="text-center">
    <h1>Api Hospitales Cliente</h1>
    <hr />
    <button id="btnhospitales" class="btn btn-outline-dark">Load Hospitales</button>
    <table id="tablahospitales" class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Direcion</th>
                <th>Telefono</th>
                <th>Camas</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>